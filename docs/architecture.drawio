<mxfile host="app.diagrams.net" modified="2026-04-01" agent="MCPGuard" version="24.0.0">
  <diagram id="mcpguard-architecture" name="Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="MCPGuard Architecture -- 4-Layer Detection Pipeline" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fillColor=#1a1a2e;fontColor=#ffffff;rounded=1;arcSize=8;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="1000" height="40" as="geometry"/>
        </mxCell>

        <!-- CLI -->
        <mxCell id="cli" value="&lt;b&gt;CLI (Typer + Rich)&lt;/b&gt;&lt;br&gt;mcpguard scan | baseline | eval | serve&lt;br&gt;Output: Rich table | JSON | SARIF&lt;br&gt;&lt;font color='#888'&gt;Exit codes: 0 clean | 1 findings | 2 error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9e9e9e;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="460" height="80" as="geometry"/>
        </mxCell>

        <!-- MCP Server -->
        <mxCell id="mcp" value="&lt;b&gt;MCP Server (FastMCP)&lt;/b&gt;&lt;br&gt;scan_server | check_tool | list_rules&lt;br&gt;Claude Desktop / Cursor integration&lt;br&gt;&lt;font color='#888'&gt;Structured JSON via MCP protocol&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9e9e9e;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="460" height="80" as="geometry"/>
        </mxCell>

        <!-- Scan Orchestrator -->
        <mxCell id="orchestrator" value="&lt;b&gt;Scan Orchestrator (scanner.py)&lt;/b&gt;&lt;br&gt;Connect → Enumerate tools/resources → Run detectors per tool → Generate report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#7e57c2;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="200" width="770" height="50" as="geometry"/>
        </mxCell>

        <!-- Arrows to orchestrator -->
        <mxCell id="e1" edge="1" source="cli" target="orchestrator" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" edge="1" source="mcp" target="orchestrator" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Detection Pipeline Container -->
        <mxCell id="pipeline" value="Detection Pipeline" style="swimlane;startSize=25;fillColor=#ffffff;strokeColor=#bdbdbd;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="290" width="580" height="380" as="geometry"/>
        </mxCell>

        <!-- Layer 1 -->
        <mxCell id="l1" value="&lt;b&gt;Layer 1: Static Rules ($0)&lt;/b&gt;&lt;br&gt;Poisoning detector -- directive tags, exfiltration patterns&lt;br&gt;Credential detector -- 25+ secret types&lt;br&gt;Unicode detector -- invisible characters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#66bb6a;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;" vertex="1" parent="pipeline">
          <mxGeometry x="15" y="35" width="550" height="70" as="geometry"/>
        </mxCell>

        <!-- Layer 2 -->
        <mxCell id="l2" value="&lt;b&gt;Layer 2: Schema Heuristics ($0)&lt;/b&gt;&lt;br&gt;Full-schema detector -- CyberArk-style param name attacks&lt;br&gt;SSRF detector -- URL params without constraints&lt;br&gt;Command injection -- shell metacharacters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ffa726;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;" vertex="1" parent="pipeline">
          <mxGeometry x="15" y="115" width="550" height="70" as="geometry"/>
        </mxCell>

        <!-- Layer 3 -->
        <mxCell id="l3" value="&lt;b&gt;Layer 3: LLM Semantic Analysis (~$0.02/scan)&lt;/b&gt;&lt;br&gt;PydanticAI agent -- Gemini 2.5 Flash (free) / Groq fallback&lt;br&gt;Ambiguous findings only (~10-20% of tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#42a5f5;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;" vertex="1" parent="pipeline">
          <mxGeometry x="15" y="195" width="550" height="60" as="geometry"/>
        </mxCell>

        <!-- Layer 4 -->
        <mxCell id="l4" value="&lt;b&gt;Layer 4: Integrity Verification ($0)&lt;/b&gt;&lt;br&gt;Rug pull detector -- SHA-256 hash pinning + baseline compare&lt;br&gt;Auth compliance -- OAuth 2.1, transport security" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#ef5350;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;" vertex="1" parent="pipeline">
          <mxGeometry x="15" y="265" width="550" height="60" as="geometry"/>
        </mxCell>

        <!-- Report -->
        <mxCell id="report" value="&lt;b&gt;ServerAuditReport&lt;/b&gt; -- findings, risk score, OWASP mapping, remediation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;align=center;verticalAlign=middle;fontSize=11;" vertex="1" parent="pipeline">
          <mxGeometry x="15" y="340" width="550" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow from orchestrator to pipeline -->
        <mxCell id="e3" edge="1" source="orchestrator" target="pipeline" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Target MCP Server -->
        <mxCell id="target" value="&lt;b&gt;Target MCP Server&lt;/b&gt;&lt;br&gt;&lt;br&gt;Connected via:&lt;br&gt;  MCPServerStdio (local)&lt;br&gt;  MCPServerStreamableHTTP (remote)&lt;br&gt;&lt;br&gt;Introspected:&lt;br&gt;  list_tools() | list_resources()&lt;br&gt;  capabilities | server_info" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bdbdbd;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="680" y="290" width="340" height="150" as="geometry"/>
        </mxCell>

        <!-- Config -->
        <mxCell id="config" value="&lt;b&gt;Configuration&lt;/b&gt;&lt;br&gt;&lt;br&gt;Settings -- .env (SecretStr masked)&lt;br&gt;ScanConfig -- frozen, immutable&lt;br&gt;ScanState -- mutable accumulator&lt;br&gt;Logging -- stdlib + optional Logfire" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bdbdbd;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="680" y="460" width="340" height="100" as="geometry"/>
        </mxCell>

        <!-- Observability -->
        <mxCell id="obs" value="&lt;b&gt;Observability&lt;/b&gt;&lt;br&gt;Pydantic Logfire (OTel, 10M spans/mo free)&lt;br&gt;Cost tracking per scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bdbdbd;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="580" width="340" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow from orchestrator to target -->
        <mxCell id="e4" edge="1" source="orchestrator" target="target" parent="1" style="dashed=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
